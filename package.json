{
  "name": "superqat",
  "version": "2.0.0",
  "description": "Office Add-in: all 649 Quick Access Toolbar commands in one dropdown",
  "main": "electron/main.js",
  "scripts": {
    "start": "webpack serve --config webpack.config.js --mode development",
    "build": "webpack --config webpack.config.js --mode production",
    "electron": "npm run build && electron electron/main.js",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:all": "npm run build && electron-builder --win --mac",
    "sideload:word": "office-addin-debugging start manifests/word-manifest.xml",
    "sideload:excel": "office-addin-debugging start manifests/excel-manifest.xml",
    "sideload:powerpoint": "office-addin-debugging start manifests/powerpoint-manifest.xml",
    "validate": "office-addin-manifest validate manifests/word-manifest.xml && office-addin-manifest validate manifests/excel-manifest.xml && office-addin-manifest validate manifests/powerpoint-manifest.xml",
    "build:prod": "webpack --config webpack.prod.js",
    "deploy:local": "node scripts/set-host.js local && npm run build",
    "deploy:remote": "node scripts/set-host.js",
    "cap:sync": "npm run build:prod && cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "set-host": "node scripts/set-host.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.89"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.0",
    "office-addin-manifest": "^1.13.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "optionalDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8"
  },
  "license": "MIT"
}
